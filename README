import numpy as np
from sklearn.datasets import fetch_openml

# 1. MNIST 데이터 불러오기 (처음 실행 시 시간이 좀 걸립니다)
print("데이터 로딩 중...")
mnist = fetch_openml('mnist_784', version=1, as_frame=False)
X = mnist.data # 70,000개의 이미지 데이터

# 2. 0번 인덱스 숫자 하나만 꺼내서 바이너리(-1, 1)로 변환
sample_digit = np.where(X[0] > 127, 1, -1)

# 3. 이전에 만든 텍스트 출력 함수로 확인
def print_digit(vector):
    matrix = vector.reshape(28, 28)
    for row in matrix:
        print("".join(["#" if x == 1 else "." for x in row]))

print_digit(sample_digit)
